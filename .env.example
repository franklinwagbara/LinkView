# Signaling server WebSocket URL (auto-detected in dev and production)
NEXT_PUBLIC_SIGNALING_URL=

# ─── TURN Server (REQUIRED for cross-network connections) ─────────────────
# Without TURN, peers behind symmetric NATs cannot connect.
# TURN credentials are served at runtime via /api/ice-servers so they
# are never baked into the client bundle.
#
# OPTION 1 (recommended): Metered.ca REST API — fetches fresh credentials
#   Sign up free at https://www.metered.ca/stun-turn (500 GB/month free)
#   1. Create an app (e.g. "linkview")
#   2. Copy the API key
#   3. Set these env vars on Render:
METERED_APP_NAME=linkview
METERED_API_KEY=
#
# OPTION 2: Manual TURN credentials
#   Get credentials from any TURN provider (Xirsys, Twilio, self-hosted coturn)
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# Server port
PORT=3000
