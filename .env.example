# Signaling server WebSocket URL (auto-detected in dev)
NEXT_PUBLIC_SIGNALING_URL=

# STUN servers (comma-separated, defaults to Google STUN servers)
NEXT_PUBLIC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# ─── TURN Server (REQUIRED for cross-network connections) ─────────────────
# Without TURN, peers behind symmetric NATs cannot connect.
#
# Free TURN providers:
#   Metered (metered.ca)    — 500GB/month free, sign up at https://www.metered.ca/stun-turn
#   Xirsys  (xirsys.com)    — 500MB/month free
#   Twilio  (twilio.com)    — free trial credits
#
# Example with Metered (after signup):
#   NEXT_PUBLIC_TURN_URLS=turn:global.relay.metered.ca:80,turn:global.relay.metered.ca:443,turns:global.relay.metered.ca:443?transport=tcp
#   NEXT_PUBLIC_TURN_USERNAME=<your-api-key>
#   NEXT_PUBLIC_TURN_CREDENTIAL=<your-api-key>
#
# Single URL (legacy):
NEXT_PUBLIC_TURN_URL=
# Multiple URLs (comma-separated, preferred):
NEXT_PUBLIC_TURN_URLS=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

# Server port
PORT=3000
